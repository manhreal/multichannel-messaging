# Server
PORT=3300
NODE_ENV=development

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=multichannel_messaging

# Redis (optional, chưa dùng)
REDIS_URL=redis://localhost:6379

# Meta App — lấy từ developers.facebook.com > Cài đặt ứng dụng > Cơ bản
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=my_custom_verify_token_123

# Facebook Messenger — lấy từ Messenger API Settings > Tạo mã truy cập
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=

# Instagram — lấy từ Instagram API Settings > Tạo mã truy cập
IG_PAGE_ACCESS_TOKEN=
IG_ACCOUNT_ID=

# WhatsApp Business — lấy từ WhatsApp API Setup
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_ACCESS_TOKEN=

# Ngrok — điền sau khi chạy: ngrok http 3300
WEBHOOK_BASE_URL=https://xxxx.ngrok-free.app
